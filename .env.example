# Shared
NODE_ENV=development
JWT_ACCESS_SECRET=replace_with_long_random_secret
JWT_REFRESH_SECRET=replace_with_long_random_secret
OPENAI_API_KEY=replace_me
OPENAI_MODEL=gpt-5-mini
APP_URL=http://localhost:5173
API_URL=http://localhost:3333
VITE_API_URL=http://localhost:3333
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Uploads / storage metadata
STORAGE_PROVIDER=external
STORAGE_BUCKET=lumnipsi-assets
STORAGE_REGION=us-east-1
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=

# Assistant safety
ASSISTANT_ENABLED=true
ASSISTANT_ALLOW_DB_WRITE=false
ASSISTANT_SYSTEM_NAME=Lia
